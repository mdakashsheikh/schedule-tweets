<h1 class="text-center text-2xl font-semibold mt-5">Forgot your password?</h1>

<%= form_with url: password_reset_path,
    class: "max-w-md mx-auto mt-10 p-6 bg-white shadow-md rounded-lg" do |form| %>
  
  <div class="mb-4">
    <%= form.label :email, class: "block text-gray-700 font-medium mb-2"%>
    <%= form.text_field :email, class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
  </div>
  
  <div>
    <%= form.submit "Reset Password", class: "w-full bg-blue-500 hover:bg-blue-600 text-white font-bold py-2 px-4 rounded-lg transition-colors duration-200" %>
  </div>
<% end %>