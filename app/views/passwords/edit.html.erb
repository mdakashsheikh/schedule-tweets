<h1 class="text-center text-2xl font-semibold mt-5">Edit Password</h1>

<%= form_with model: Current.user, url: edit_password_path,
      class: "max-w-md mx-auto mt-10 p-6 bg-white shadow-md rounded-lg" do |form| %>
      
  <% if form.object.errors.any? %>
    <div class="p-4 mb-4 text-sm text-gray-800 bg-red-100 rounded-lg" role="alert">
      <% form.object.errors.full_messages.each do |message| %>
        <div><%= message %></div>
      <% end %>
    </div>
  <% end %>

  <div class="mb-4">
    <%= form.label :password, class: "block text-gray-700 font-medium mb-2" %>
    <%= form.password_field :password, class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
  </div>

  <div class="mb-6">
    <%= form.label :password_confirmation, class: "block text-gray-700 font-medium mb-2" %>
    <%= form.password_field :password_confirmation, class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
  </div>

  <div>
    <%= form.submit "Update Password", class: "w-full bg-blue-500 hover:bg-blue-600 text-white font-bold py-2 px-4 rounded-lg transition-colors duration-200" %>
  </div>

<% end %>